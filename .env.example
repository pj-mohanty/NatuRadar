# Copy this file to .env and fill in your own values

# Anthropic / Claude API key (server-side only, not exposed to browser)
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# iNaturalist JWT token (server-side only, not exposed to browser)
# Get yours at https://www.inaturalist.org/users/api_token
INAT_TOKEN=

# Firebase project configuration
# Find these in your Firebase console → Project settings → Your apps
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
